{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "catalog-schema.json",
  "type": "object",
  "required": ["version", "author", "skills"],
  "properties": {
    "version": { "type": "string" },
    "author": { "type": "string" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "repo", "version", "license", "platforms"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "description": { "type": "string", "maxLength": 200 },
          "repo": { "type": "string", "format": "uri" },
          "version": { "type": "string" },
          "license": { "type": "string" },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["claude-code", "cursor", "claude-web", "claude-cowork", "codex"]
            }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
